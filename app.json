{
  "expo": {
    "name": "Avant Regard",
    "slug": "avant-regard",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Avant Regard 需要访问您的相册来选择图片",
        "NSCameraUsageDescription": "Avant Regard 需要访问相机来拍摄照片",
        "NSPhotoLibraryAddUsageDescription": "Avant Regard 需要保存编辑后的图片到相册"
      },
      "bundleIdentifier": "com.yanggg96.avant-regard"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font"
    ]
  }
}
